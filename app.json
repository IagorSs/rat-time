{
  "expo": {
    "name": "Rat Time",
    "slug": "rat-time-app",
    "version": "0.0.1",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "ratTime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FCDEDE",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.iagorss.rattime.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b13f35b-95bc-4aea-aee2-1f7887404506"
      }
    }
  }
}
